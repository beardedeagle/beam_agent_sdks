{application, agent_wire, [
    {description, "Shared foundation for BEAM agent SDK wire protocols"},
    {vsn, "0.1.0"},
    {registered, []},
    {applications, [
        kernel,
        stdlib,
        telemetry
    ]},
    {env, []},
    {modules, [
        agent_wire,
        agent_wire_behaviour,
        agent_wire_checkpoint,
        agent_wire_command,
        agent_wire_content,
        agent_wire_control,
        agent_wire_hooks,
        agent_wire_jsonl,
        agent_wire_jsonrpc,
        agent_wire_mcp,
        agent_wire_queue,
        agent_wire_session_store,
        agent_wire_telemetry,
        agent_wire_threads,
        agent_wire_todo,
        agent_wire_transport
    ]}
]}.
